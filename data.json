  "grammaire": [
    {
      "id": "g1",
      "titre": "Le masculin et le féminin",
      "explication_fr": "Beaucoup de mots changent selon qui parle ou à qui on parle. Souvent, la forme féminine ajoute un son 'é' ou 'a' à la fin.",
      "exemple_fr": "Tu es content (à un homme) / Tu es contente (à une femme)",
      "exemple_lb_latin": "Mabsout / Mabsouté",
      "exemple_lb_arabic": "مبسوط / مبسوطة"
    },
    {
      "id": "g2",
      "titre": "Le présent avec 'b'",
      "explication_fr": "Au Liban, on ajoute souvent un 'b' ou 'm' devant le verbe conjugué pour marquer le présent habituel, un peu comme une action régulière.",
      "exemple_fr": "Je mange (tous les jours)",
      "exemple_lb_latin": "Bekol",
      "exemple_lb_arabic": "بوكل"
    },
    {
      "id": "g3",
      "titre": "Poser une question",
      "explication_fr": "Le mot 'shu' veut dire 'quoi' ou 'quel/quelle' et se place souvent en début de phrase.",
      "exemple_fr": "Quel est ton nom ?",
      "exemple_lb_latin": "Shu ismak ?",
      "exemple_lb_arabic": "شو اسمك؟"
    }
  ]
