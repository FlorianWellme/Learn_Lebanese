  "phrases": [
    { "id": "p1", "fr": "Comment ça va ?", "lb_latin": "Kifak / Kifik ?", "lb_arabic": "كيفك؟" },
    { "id": "p2", "fr": "Je vais bien, merci.", "lb_latin": "Mniih, merci.", "lb_arabic": "منيح، مرسي." },
    { "id": "p3", "fr": "Comment tu t'appelles ?", "lb_latin": "Shu esmak / esmik ?", "lb_arabic": "شو اسمك؟" },
    { "id": "p4", "fr": "Je m'appelle...", "lb_latin": "esmi...", "lb_arabic": "اسمي..." },
    { "id": "p5", "fr": "Où habites-tu ?", "lb_latin": "Wén sekné / sekné ?", "lb_arabic": "وين ساكن؟" },
    { "id": "p6", "fr": "Je ne comprends pas.", "lb_latin": "Ma fehmt / fehmt.", "lb_arabic": "مش فاهم." },
    { "id": "p7", "fr": "Merci beaucoup.", "lb_latin": "Shukran ktir.", "lb_arabic": "يسلمو." },
    { "id": "p8", "fr": "Comment est le temps aujourd'hui ?", "lb_latin": "Kif el ta'is el lyom ?", "lb_arabic": "كيف الطقس اليوم؟" },
    { "id": "p9", "fr": "Comment était le temps dehors ?", "lb_latin": "Kif el jaw barah ?", "lb_arabic": "كيف كان الطقس في الخارج؟" },
    { "id": "p10", "fr": "Quelle est la température ?", "lb_latin": "Adaysh darajit el harara ?", "lb_arabic": "ما هي درجة الحرارة؟" },
    { "id": "p11", "fr": "Il fait froid.", "lb_latin": "El dinya bardeh", "lb_arabic": "الطقس بارد" },
    { "id": "p12", "fr": "Il fait chaud.", "lb_latin": "El ta'is shob", "lb_arabic": "الطقس حار" },
    { "id": "p13", "fr": "Il fait beau.", "lb_latin": "El ta'is helaw", "lb_arabic": "الطقس جميل" },
    { "id": "p14", "fr": "Le temps est magnifique.", "lb_latin": "El jaw ra'e", "lb_arabic": "الطقس مذهل" },
    { "id": "p15", "fr": "Le ciel est dégagé.", "lb_latin": "El sama safiyah", "lb_arabic": "السماء نظيفة" },
    { "id": "p16", "fr": "Il pleut.", "lb_latin": "3am Tishti", "lb_arabic": "يتساقط المطر" },
    { "id": "p17", "fr": "Il neige.", "lb_latin": "3am Tishti talij", "lb_arabic": "يتساقط الثلج" },
    { "id": "p18", "fr": "Que Dieu te facilite les choses.", "lb_latin": "Allah ye sahil alak / alik", "lb_arabic": "الله يسهل عليك" },
    { "id": "p19", "fr": "Bon voyage, prends soin de toi.", "lb_latin": "Maa Al-Salama", "lb_arabic": "مع السلامة" },
    { "id": "p20", "fr": "Es-tu arrivé(e) ?", "lb_latin": "Wuslet / Wuselete ?", "lb_arabic": "وصلت؟" },
    { "id": "p21", "fr": "Ma sœur est toujours positive.", "lb_latin": "Ukhte dayman ijaabyeh", "lb_arabic": "أختي دايمًا إيجابية" },
    { "id": "p22", "fr": "Je veux dire ça.", "lb_latin": "Ya'ne enno like", "lb_arabic": "أعني ذلك" },
    { "id": "p23", "fr": "D'accord, c'est bon.", "lb_latin": "Fa khalas", "lb_arabic": "حسنًا، الأمر جيد" },
    { "id": "p24", "fr": "Je veux dire, je l'ai vu de loin.", "lb_latin": "Ya'ne shuftha min b'eed", "lb_arabic": "أعني أنني رأيتها من بعيد" },
    { "id": "p25", "fr": "Il a dit qu'il ne vient pas aujourd'hui.", "lb_latin": "'Aal enno ma rah yiji el-lyom", "lb_arabic": "قال أنه لن يأتِ اليوم" },
    { "id": "p26", "fr": "J'aime la nourriture libanaise, comme le taboulé et la knefe.", "lb_latin": "Behebb el akel el lebnéni, ya'ne enno el tabbouleh w el knefe", "lb_arabic": "أحب الطعام اللبناني، يعني التبولة والكنافة" },
    { "id": "p27", "fr": "D'accord, je te comprends.", "lb_latin": "Khalas, fehmt 3alak", "lb_arabic": "حسنًا، فهمت لك" },
    { "id": "p28", "fr": "Je me suis dit qu'il fallait que j'essaie.", "lb_latin": "Fa'ult lahale lazim ajarrib", "lb_arabic": "قلت له أنه يجب أن أحاول" },
    { "id": "p29", "fr": "Honnêtement, je n'ai pas aimé le film.", "lb_latin": "Bi-saraha, ma habayt el film", "lb_arabic": "بصراحة، ما حبيت الفيلم" },
    { "id": "p30", "fr": "D'accord, je vais le faire comme ça.", "lb_latin": "Mashi, rah ba'mil hayk", "lb_arabic": "ماشي، رح بعمل هيك" },
    { "id": "p31", "fr": "Il n'y a vraiment rien qui cloche.", "lb_latin": "Akeed ma fi shee", "lb_arabic": "أكيد ما في شي" },
    { "id": "p32", "fr": "Je jure que je ne plaisante pas.", "lb_latin": "Eh wallah ma'em bamzah", "lb_arabic": "إيه والله مش عم بمزح" },
    { "id": "p33", "fr": "Il fait vraiment chaud aujourd'hui.", "lb_latin": "'Anjad shob el lyom", "lb_arabic": "عنجد شوب اليوم" },
    { "id": "p34", "fr": "Au fait / à propos.", "lb_latin": "'Afikra", "lb_arabic": "بالمناسبة" },
    { "id": "p35", "fr": "Oui, je l'ai vu hier.", "lb_latin": "Eh shufta embarih", "lb_arabic": "إيه شفتا امبارح" }
  ],
