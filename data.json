  "phrases": [
    {
      "id": "p1",
      "fr": "Comment ça va ?",
      "lb_latin": "Kifak / Kifik ?",
      "lb_arabic": "كيفك؟",
      "theme": "salutations"
    },
    {
      "id": "p2",
      "fr": "Je vais bien, merci.",
      "lb_latin": "Mniih, merci.",
      "lb_arabic": "منيح، مرسي.",
      "theme": "salutations"
    },
    {
      "id": "p3",
      "fr": "Comment tu t'appelles ?",
      "lb_latin": "Shu esmak / esmik ?",
      "lb_arabic": "شو اسمك؟",
      "theme": "salutations"
    },
    {
      "id": "p4",
      "fr": "Je m'appelle...",
      "lb_latin": "esmi...",
      "lb_arabic": "اسمي...",
      "theme": "salutations"
    },
    {
      "id": "p5",
      "fr": "Où habites-tu ?",
      "lb_latin": "Wén sekné / sekné ?",
      "lb_arabic": "وين ساكن؟",
      "theme": "salutations"
    },
    {
      "id": "p6",
      "fr": "Je ne comprends pas.",
      "lb_latin": "Ma fehmt / fehmt.",
      "lb_arabic": "مش فاهم.",
      "theme": "salutations"
    },
    {
      "id": "p7",
      "fr": "Merci beaucoup.",
      "lb_latin": "Shukran ktir.",
      "lb_arabic": "يسلمو.",
      "theme": "salutations"
    },
    {
      "id": "p8",
      "fr": "Comment est le temps aujourd'hui ?",
      "lb_latin": "Kif el ta'is el lyom ?",
      "lb_arabic": "كيف الطقس اليوم؟",
      "theme": "météo"
    },
    {
      "id": "p9",
      "fr": "Comment était le temps dehors ?",
      "lb_latin": "Kif el jaw barah ?",
      "lb_arabic": "كيف كان الطقس في الخارج؟",
      "theme": "météo"
    },
    {
      "id": "p10",
      "fr": "Quelle est la température ?",
      "lb_latin": "Adaysh darajit el harara ?",
      "lb_arabic": "ما هي درجة الحرارة؟",
      "theme": "météo"
    },
    {
      "id": "p11",
      "fr": "Il fait froid.",
      "lb_latin": "El dinya bardeh",
      "lb_arabic": "الطقس بارد",
      "theme": "météo"
    },
    {
      "id": "p12",
      "fr": "Il fait chaud.",
      "lb_latin": "El ta'is shob",
      "lb_arabic": "الطقس حار",
      "theme": "météo"
    },
    {
      "id": "p13",
      "fr": "Il fait beau.",
      "lb_latin": "El ta'is helaw",
      "lb_arabic": "الطقس جميل",
      "theme": "météo"
    },
    {
      "id": "p14",
      "fr": "Le temps est magnifique.",
      "lb_latin": "El jaw ra'e",
      "lb_arabic": "الطقس مذهل",
      "theme": "météo"
    },
    {
      "id": "p15",
      "fr": "Le ciel est dégagé.",
      "lb_latin": "El sama safiyah",
      "lb_arabic": "السماء نظيفة",
      "theme": "météo"
    },
    {
      "id": "p16",
      "fr": "Il pleut.",
      "lb_latin": "3am Tishti",
      "lb_arabic": "يتساقط المطر",
      "theme": "météo"
    },
    {
      "id": "p17",
      "fr": "Il neige.",
      "lb_latin": "3am Tishti talij",
      "lb_arabic": "يتساقط الثلج",
      "theme": "météo"
    },
    {
      "id": "p18",
      "fr": "Que Dieu te facilite les choses.",
      "lb_latin": "Allah ye sahil alak / alik",
      "lb_arabic": "الله يسهل عليك",
      "theme": "expression"
    },
    {
      "id": "p19",
      "fr": "Bon voyage, prends soin de toi.",
      "lb_latin": "Maa Al-Salama",
      "lb_arabic": "مع السلامة",
      "theme": "voyage"
    },
    {
      "id": "p20",
      "fr": "Es-tu arrivé(e) ?",
      "lb_latin": "Wuslet / Wuselete ?",
      "lb_arabic": "وصلت؟",
      "theme": "voyage"
    },
    {
      "id": "p21",
      "fr": "Ma sœur est toujours positive.",
      "lb_latin": "Ukhte dayman ijaabyeh",
      "lb_arabic": "أختي دايمًا إيجابية",
      "theme": "famille"
    },
    {
      "id": "p22",
      "fr": "Je veux dire ça.",
      "lb_latin": "Ya'ne enno like",
      "lb_arabic": "أعني ذلك",
      "theme": "expression"
    },
    {
      "id": "p23",
      "fr": "D'accord, c'est bon.",
      "lb_latin": "Fa khalas",
      "lb_arabic": "حسنًا، الأمر جيد",
      "theme": "expression"
    },
    {
      "id": "p24",
      "fr": "Je veux dire, je l'ai vu de loin.",
      "lb_latin": "Ya'ne shuftha min b'eed",
      "lb_arabic": "أعني أنني رأيتها من بعيد",
      "theme": "expression"
    },
    {
      "id": "p25",
      "fr": "Il a dit qu'il ne vient pas aujourd'hui.",
      "lb_latin": "'Aal enno ma rah yiji el-lyom",
      "lb_arabic": "قال أنه لن يأتِ اليوم",
      "theme": "expression"
    },
    {
      "id": "p26",
      "fr": "J'aime la nourriture libanaise, comme le taboulé et la knefe.",
      "lb_latin": "Behebb el akel el lebnéni, ya'ne enno el tabbouleh w el knefe",
      "lb_arabic": "أحب الطعام اللبناني، يعني التبولة والكنافة",
      "theme": "nourriture"
    },
    {
      "id": "p27",
      "fr": "D'accord, je te comprends.",
      "lb_latin": "Khalas, fehmt 3alak",
      "lb_arabic": "حسنًا، فهمت لك",
      "theme": "expression"
    },
    {
      "id": "p28",
      "fr": "Je me suis dit qu'il fallait que j'essaie.",
      "lb_latin": "Fa'ult lahale lazim ajarrib",
      "lb_arabic": "قلت له أنه يجب أن أحاول",
      "theme": "expression"
    },
    {
      "id": "p29",
      "fr": "Honnêtement, je n'ai pas aimé le film.",
      "lb_latin": "Bi-saraha, ma habayt el film",
      "lb_arabic": "بصراحة، ما حبيت الفيلم",
      "theme": "expression"
    },
    {
      "id": "p30",
      "fr": "D'accord, je vais le faire comme ça.",
      "lb_latin": "Mashi, rah ba'mil hayk",
      "lb_arabic": "ماشي، رح بعمل هيك",
      "theme": "expression"
    },
    {
      "id": "p31",
      "fr": "Il n'y a vraiment rien qui cloche.",
      "lb_latin": "Akeed ma fi shee",
      "lb_arabic": "أكيد ما في شي",
      "theme": "expression"
    },
    {
      "id": "p32",
      "fr": "Je jure que je ne plaisante pas.",
      "lb_latin": "Eh wallah ma'em bamzah",
      "lb_arabic": "إيه والله مش عم بمزح",
      "theme": "expression"
    },
    {
      "id": "p33",
      "fr": "Il fait vraiment chaud aujourd'hui.",
      "lb_latin": "'Anjad shob el lyom",
      "lb_arabic": "عنجد شوب اليوم",
      "theme": "météo"
    },
    {
      "id": "p34",
      "fr": "Au fait / à propos.",
      "lb_latin": "'Afikra",
      "lb_arabic": "بالمناسبة",
      "theme": "expression"
    },
    {
      "id": "p35",
      "fr": "Oui, je l'ai vu hier.",
      "lb_latin": "Eh shufta embarih",
      "lb_arabic": "إيه شفتا امبارح",
      "theme": "expression"
    },
    {
      "id": "p51",
      "fr": "Excellent, tout le monde !",
      "lb_latin": "Mumtaz ya shebab",
      "lb_arabic": "ممتاز يا شباب",
      "theme": "expression"
    },
    {
      "id": "p52",
      "fr": "Qu'as-tu fait hier après le travail ?",
      "lb_latin": "Shu sawet imbara baad ichiril ?",
      "lb_arabic": "",
      "theme": "quotidien"
    },
    {
      "id": "p53",
      "fr": "J'ai fait une fête jeudi dernier.",
      "lb_latin": "Sawet afle lyom el-khamis el-madi.",
      "lb_arabic": "",
      "theme": "quotidien"
    },
    {
      "id": "p54",
      "fr": "Nous avons fait tous les devoirs.",
      "lb_latin": "Saweyna kil al-wasayef.",
      "lb_arabic": "",
      "theme": "quotidien"
    },
    {
      "id": "p55",
      "fr": "Elle veut faire son anniversaire dans ce restaurant.",
      "lb_latin": "Bidda itsawe aïd-milada bihada al-matam.",
      "lb_arabic": "",
      "theme": "quotidien"
    },
    {
      "id": "p56",
      "fr": "Qu'est-ce que tu vas faire vendredi ?",
      "lb_latin": "Shu biddak itsawe lyom al-jumua ?",
      "lb_arabic": "",
      "theme": "quotidien"
    },
    {
      "id": "p57",
      "fr": "Je suis en train de faire...",
      "lb_latin": "3am btsawi...",
      "lb_arabic": "",
      "theme": "quotidien"
    },
    {
      "id": "p58",
      "fr": "Tu vas faire l'examen dimanche.",
      "lb_latin": "Rah tsawi al-imtham lyom al-ahad.",
      "lb_arabic": "",
      "theme": "quotidien"
    }
  ],
